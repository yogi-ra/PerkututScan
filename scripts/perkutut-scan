  fi
}

runSafetyScan() {
  local source="$1"
  local real_target="$2"
  local temp_dir="$3"

  if [[ "$SECURITY_SCAN_SAFETY_AVAILABLE" != "true" ]] || [[ ! -f "${real_target}/requirements.txt" ]]; then
    if [[ ! -f "${real_target}/requirements.txt" ]]; then
      echo "⚠️  Skipping Safety scan (requirements.txt not found)"
    else
      echo "⚠️  Skipping Safety scan (safety not available)"
    fi
    return
  fi

  echo "🔍 Running Safety Dependency Vulnerability Check..."
  {
    echo "## Safety Dependency Vulnerability Check"
    echo ""
    echo "Command: safety check -r \"${real_target}/requirements.txt\" --bare"
    echo ""
    echo "Output:"
    echo "$()$("
    safety check -r "${real_target}/requirements.txt" --bare | tee "${temp_dir}/safety.txt"
    echo ")$()"
    echo ""
  } >>"${temp_dir}/security-scan-report.md"

  # Also generate simplified JSON output for integration with main report
  # Safety output format: package_name version_spec vulnerability_id [more_info]
  # We'll convert to our format
  if command -v safety >/dev/null 2>&1 && [[ -f "${real_target}/requirements.txt" ]]; then
    # Create temporary file for safety JSON output
    local safety_json_output="${temp_dir}/safety.json"
    echo "[]" > "$safety_json_output"  # Start with empty array

    # Process safety output line by line
    while IFS= read -r line; do
      if [[ -n "$line" && ! "$line" =~ ^[[:space:]]*$ ]]; then
        # Parse safety output: package version vulnerability [more info]
        # Example: "django 2.0.0 CVE-2019-14234 (https://vuldb.com/?id.123456)"
        local pkg_ver_vuln=($line)
        if [[ ${#pkg_ver_vuln[@]} -ge 3 ]]; then
          local package="${pkg_ver_vuln[0]}"
          local version="${pkg_ver_vuln[1]}"
          local vulnerability=""
          local info=""

          # Extract vulnerability ID (might be multiple)
          for ((i=2; i<${#pkg_ver_vuln[@]}; i++)); do
            if [[ "${pkg_ver_vuln[i]}" == CVE-* ]] || [[ "${pkg_ver_vuln[i]}" == PYSEC-* ]] || [[ "${pkg_ver_vuln[i]}" == GHSA-* ]]; then
              vulnerability="${pkg_ver_vuln[i]}"
              break
            fi
          done

          # If no specific vulnerability ID found, use the third field
          if [[ -z "$vulnerability" ]]; then
            vulnerability="${pkg_ver_vuln[2]}"
          fi

          # Create JSON object for this finding
          local json_obj=$(jq -n \
            --arg pkg "$package" \
            --arg ver "$version" \
            --arg vuln "$vulnerability" \
            --arg info "$info" \
            '{template-id: "safety-" + $vuln, matched-at: "requirements.txt", extracted-results: [$pkg, $ver], severity: "medium"}')

          # Append to array
          if [[ -f "$safety_json_output" ]]; then
            jq --argjson new "$json_obj" '. + [$new]' "$safety_json_output" > "${safety_json_output}.tmp" && mv "${safety_json_output}.tmp" "$safety_json_output"
          fi
        fi
      fi
    done < <(safety check -r "${real_target}/requirements.txt" --bare 2>/dev/null || true)
  fi
}

runPipAuditScan() {
  local source="$1"
  local real_target="$2"
  local temp_dir="$3"

  if [[ "$SECURITY_SCAN_PIP_AUDIT_AVAILABLE" != "true" ]] || [[ ! -f "${real_target}/requirements.txt" ]]; then
    if [[ ! -f "${real_target}/requirements.txt" ]]; then
      echo "⚠️  Skipping Pip-Audit scan (requirements.txt not found)"
    else
      echo "⚠️  Skipping Pip-Audit scan (pip-audit not available)"
    fi
    return
  fi

  echo "🔍 Running Pip-Audit Dependency Vulnerability Check..."
  {
    echo "## Pip-Audit Dependency Vulnerability Check"
    echo ""
    echo "Command: pip-audit -r \"${real_target}/requirements.txt\" --format txt"
    echo ""
    echo "Output:"
    echo "$()$("
    pip-audit -r "${real_target}/requirements.txt" --format txt | tee "${temp_dir}/pip-audit.txt"
    echo ")$()"
    echo ""
  } >>"${temp_dir}/security-scan-report.md"

  # Also generate JSON output for integration with main report
  if command -v pip-audit >/dev/null 2>&1 && [[ -f "${real_target}/requirements.txt" ]]; then
    # Create temporary file for pip-audit JSON output
    local pip_audit_json_output="${temp_dir}/pip-audit.json"
    echo "[]" > "$pip_audit_json_output"  # Start with empty array

    # Process pip-audit output line by line (txt format)
    # Format: package: version: vulnerability ID [more info]
    while IFS= read -r line; do
      if [[ -n "$line" && ! "$line" =~ ^[[:space:]]*$ && ! "$line" =~ ^Scanning && ! "$line" =~ ^Collecting ]]; then
        # Parse pip-audit output: package: version: vulnerability ID
        # Example: "django: 2.0.0: CVE-2019-14234"
        if [[ "$line" =~ : ]]; then
          IFS=':' read -r pkg_ver vuln <<< "$line"
          # Further split package and version
          IFS=' ' read -r package version <<< "$pkg_ver"
          # Remove leading/trailing whitespace
          package=$(echo "$package" | xargs)
          version=$(echo "$version" | xargs)
          vuln=$(echo "$vuln" | xargs)

          if [[ -n "$package" && -n "$version" && -n "$vuln" ]]; then
            # Create JSON object for this finding
            local json_obj=$(jq -n \
              --arg pkg "$package" \
              --arg ver "$version" \
              --arg vuln "$vuln" \
              '{template-id: "pip-audit-" + $vuln, matched-at: "requirements.txt", extracted-results: [$pkg, $ver], severity: "high"}')

            # Append to array
            if [[ -f "$pip_audit_json_output" ]]; then
              jq --argjson new "$json_obj" '. + [$new]' "$pip_audit_json_output" > "${pip_audit_json_output}.tmp" && mv "${pip_audit_json_output}.tmp" "$pip_audit_json_output"
            fi
          fi
        fi
      fi
    done < <(pip-audit -r "${real_target}/requirements.txt" --format txt 2>/dev/null || true)
  fi
}

