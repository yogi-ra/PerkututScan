runSecurityScanWorkflow() {
  local source="$1"
  local real_target="$2"

  # Create temporary directory for security-scan outputs
  SECURITY_SCAN_TEMP_DIR=$(mktemp -d)

  # Create combined JSON output file for all security scan results
  SECURITY_SCAN_COMBINED_JSON="${SECURITY_SCAN_TEMP_DIR}/combined-security-results.json"
  echo "[]" > "$SECURITY_SCAN_COMBINED_JSON"  # Start with empty array

  # Initialize security-scan report
  {
    echo "# Security Scan Report"
    echo "**Date:** $(date)"
    echo "**Project:** $(basename "${real_target}")"
    echo ""
  } >"${SECURITY_SCAN_TEMP_DIR}/security-scan-report.md"

  # Parse the tools to run (comma-separated list)
  IFS=',' read -ra TOOLS_ARRAY <<<"$SECURITY_SCAN_TOOLS"

  # Run selected tools
  for tool in "${TOOLS_ARRAY[@]}"; do
    case "$tool" in
    trivy)
      runTrivyScan "$source" "$real_target" "$SECURITY_SCAN_TEMP_DIR"
      # Add Trivy results to combined JSON
      if [[ -f "${SECURITY_SCAN_TEMP_DIR}/trivy_filesystem.json" && -s "${SECURITY_SCAN_TEMP_DIR}/trivy_filesystem.json" ]]; then
        jq -s '.[0] + .[1]' "$SECURITY_SCAN_COMBINED_JSON" "${SECURITY_SCAN_TEMP_DIR}/trivy_filesystem.json" > "${SECURITY_SCAN_COMBINED_JSON}.tmp" && mv "${SECURITY_SCAN_COMBINED_JSON}.tmp" "$SECURITY_SCAN_COMBINED_JSON"
      fi
      if [[ -f "${SECURITY_SCAN_TEMP_DIR}/trivy_rootfs.json" && -s "${SECURITY_SCAN_TEMP_DIR}/trivy_rootfs.json" ]]; then
        jq -s '.[0] + .[1]' "$SECURITY_SCAN_COMBINED_JSON" "${SECURITY_SCAN_TEMP_DIR}/trivy_rootfs.json" > "${SECURITY_SCAN_COMBINED_JSON}.tmp" && mv "${SECURITY_SCAN_COMBINED_JSON}.tmp" "$SECURITY_SCAN_COMBINED_JSON"
      fi
      ;;
    bandit)
      runBanditScan "$source" "$real_target" "$SECURITY_SCAN_TEMP_DIR"
      # Add Bandit results to combined JSON
      if [[ -f "${SECURITY_SCAN_TEMP_DIR}/bandit.json" && -s "${SECURITY_SCAN_TEMP_DIR}/bandit.json" ]]; then
        jq -s '.[0] + .[1]' "$SECURITY_SCAN_COMBINED_JSON" "${SECURITY_SCAN_TEMP_DIR}/bandit.json" > "${SECURITY_SCAN_COMBINED_JSON}.tmp" && mv "${SECURITY_SCAN_COMBINED_JSON}.tmp" "$SECURITY_SCAN_COMBINED_JSON"
      fi
      ;;
    safety)
      runSafetyScan "$source" "$real_target" "$SECURITY_SCAN_TEMP_DIR"
      # Add Safety results to combined JSON
      if [[ -f "${SECURITY_SCAN_TEMP_DIR}/safety.json" && -s "${SECURITY_SCAN_TEMP_DIR}/safety.json" ]]; then
        jq -s '.[0] + .[1]' "$SECURITY_SCAN_COMBINED_JSON" "${SECURITY_SCAN_TEMP_DIR}/safety.json" > "${SECURITY_SCAN_COMBINED_JSON}.tmp" && mv "${SECURITY_SCAN_COMBINED_JSON}.tmp" "$SECURITY_SCAN_COMBINED_JSON"
      fi
      ;;
    pip-audit)
      runPipAuditScan "$source" "$real_target" "$SECURITY_SCAN_TEMP_DIR"
      # Add Pip-Audit results to combined JSON
      if [[ -f "${SECURITY_SCAN_TEMP_DIR}/pip-audit.json" && -s "${SECURITY_SCAN_TEMP_DIR}/pip-audit.json" ]]; then
        jq -s '.[0] + .[1]' "$SECURITY_SCAN_COMBINED_JSON" "${SECURITY_SCAN_TEMP_DIR}/pip-audit.json" > "${SECURITY_SCAN_COMBINED_JSON}.tmp" && mv "${SECURITY_SCAN_COMBINED_JSON}.tmp" "$SECURITY_SCAN_COMBINED_JSON"
      fi
      ;;
    semgrep)
      runSemgrepScan "$source" "$real_target" "$SECURITY_SCAN_TEMP_DIR"
      # Add Semgrep results to combined JSON
      if [[ -f "${SECURITY_SCAN_TEMP_DIR}/semgrep.json" && -s "${SECURITY_SCAN_TEMP_DIR}/semgrep.json" ]]; then
        jq -s '.[0] + .[1]' "$SECURITY_SCAN_COMBINED_JSON" "${SECURITY_SCAN_TEMP_DIR}/semgrep.json" > "${SECURITY_SCAN_COMBINED_JSON}.tmp" && mv "${SECURITY_SCAN_COMBINED_JSON}.tmp" "$SECURITY_SCAN_COMBINED_JSON"
      fi
      ;;
    *)
      echo "⚠️  Unknown security-scan tool: $tool"
      ;;
    esac
  done

  # Export the combined JSON path so it's accessible to the caller
  export SECURITY_SCAN_COMBINED_JSON="${SECURITY_SCAN_TEMP_DIR}/combined-security-results.json"
}

generateSecurityScanReportSection() {
  local security_scan_report_file="$1"
  local main_report_file="$2"

  if [[ ! -f "$security_scan_report_file" ]] || [[ ! -s "$security_scan_report_file" ]]; then
    echo -e "\n⚠️  No security-scan results to include in report." >>"$main_report_file"
    return
  fi

  echo -e "\n\n====== Security-scan Results (Generated: $(date)) =======" >>"$main_report_file"
  cat "$security_scan_report_file" >>"$main_report_file"
}

git_mode_run() {
  if [[ "$GIT_TARGET_TYPE" -eq 0 ]]; then
    local original_target="$(git rev-parse --show-toplevel)"
    FILTERED_TARGET_PATH=$(run_prepare "$original_target")
  elif [[ "$GIT_TARGET_TYPE" -eq 1 ]]; then
    local original_target="$(cd "$TARGET" && git rev-parse --show-toplevel)"
    FILTERED_TARGET_PATH=$(run_prepare "$original_target")
  elif [[ "$GIT_TARGET_TYPE" -eq 2 ]]; then
    GIT_CLONED_TARGET="$(mktemp -d "/tmp/$(basename "$TARGET").XXXXXX")"

    git clone --depth 1 "$TARGET" "$GIT_CLONED_TARGET" &>/dev/null &
    spinner_run "$!" "Cloning git repository..."

    TARGET=$(cut -d. -f1 < <(echo "$GIT_CLONED_TARGET"))
    FILTERED_TARGET_PATH=$(run_prepare "$GIT_CLONED_TARGET")
  else
    exit 1
  fi

  if [[ "$GIT_TARGET_TYPE" -ne 2 ]]; then
    git_exclude_script
    ignoreSASTFile "$NUCLEI_SAST_REPORT_FILE"
  fi

  NUCLEI_OUTPUT_TMP=$(mktemp)
  NUCLEI_REPORT_FILE="$original_target/$NUCLEI_SAST_REPORT_FILE"

  {
    nuclei -file -u "$FILTERED_TARGET_PATH" \
      -s "info,low,medium,high,critical,unknown" \
      -ud "$NUCLEI_TEMPLATE_DIR" \
      -je "$NUCLEI_OUTPUT_TMP" &>/dev/null
  } &
  NUCLEI_PID=$!
}

dir_mode_run() {
  FILTERED_TARGET_PATH=$(run_prepare "$TARGET")

  NUCLEI_OUTPUT_TMP=$(mktemp)
  NUCLEI_REPORT_FILE="$TARGET/$NUCLEI_SAST_REPORT_FILE"
  {
    nuclei -file -u "$FILTERED_TARGET_PATH" \
      -s "info,low,medium,high,critical,unknown" \
      -ud "$NUCLEI_TEMPLATE_DIR" \
      -je "$NUCLEI_OUTPUT_TMP" &>/dev/null
  } &

  NUCLEI_PID=$!

}

main() {
  # Default configurable variables
  AI_URL="http://localhost:11434/v1"
  AI_MODEL="gemma3:latest"
  AI_API_KEY="ollama"
  AI_BATCH_SIZE=5

  # Security-scan variables
  RUN_SECURITY_SCAN=0
  SECURITY_SCAN_TOOLS="trivy,bandit,safety,pip-audit,semgrep" # Default to all tools
  FILTERED_TARGET_PATH=""                                     # Path to filtered target directory for scanning

  AI_USER_PROMPT=""
  AI_RESPONSE_TMPFILE=""
  GIT_TARGET_TYPE=-1   # Type 0: Current Directory, 1: Specified Directory, 2: Git Repo URL
  GIT_CLONED_TARGET="" # For git Type 2
  MODE=""
  MAJOR_VULN_FOUND=0
  NUCLEI_PID=""
  NUCLEI_REPORT_FILE=""
  NUCLEI_OUTPUT_TMP=""
  NUCLEI_SAST_REPORT_FILE="sast-report.txt"
  SHOW_HELP=0
  TARGET=""
  USE_AI=0

  parse_args "$@"

  if [[ $SHOW_HELP -eq 1 ]]; then
    case "$MODE" in
    git)
      print_git_help
      ;;
    dir)
      print_dir_help
      ;;
    *)
      echo -e "The mode option should be (git, or dir)\n"
      print_help
      ;;
    esac
    exit 0
  fi

  # GIT_TARGET_TYPE
  # 0: Current Directory
  # 1: Specified Directory
  # 2: Git Repo URL
  if [[ "$MODE" == "git" ]]; then
    if [[ -z "$TARGET" ]] && git status &>/dev/null; then
      GIT_TARGET_TYPE=0
      TARGET=$(git rev-parse --show-toplevel)
    elif [[ -d "$TARGET" ]] && git -C "$TARGET" status &>/dev/null; then
      GIT_TARGET_TYPE=1
      TARGET=$(realpath "$TARGET")
    elif curl -s --head --fail "$TARGET" &>/dev/null; then
      GIT_TARGET_TYPE=2
    else
      print_git_help
      exit 1
    fi
  elif [[ "$MODE" == "dir" ]]; then
    if [[ -z "$TARGET" || ! -d "$(realpath "$TARGET")" ]]; then
      print_dir_help
      exit 1
    fi
  else
    echo -e "❌ No valid mode (-m) provided.\n"
    print_help
    exit 1
  fi

  checkDependencies

  # Check security-scan dependencies if security-scan is enabled
  if [[ "$RUN_SECURITY_SCAN" -eq 1 ]]; then
    checkSecurityScanDependencies
  fi

  # Check if Nuclei is already running
  if ps -p $(pgrep nuclei) >/dev/null 2>&1; then
    echo "❌ Nuclei is already running in another process. Please wait for it to finish."
    exit 1
  fi

  NUCLEI_TEMPLATE_DIR="${HOME}/nuclei-templates"
  if [ "$MODE" == "dir" ]; then
    dir_mode_run
  elif [ "$MODE" == "git" ]; then
    git_mode_run
  else
    print_help
    exit 1
  fi

  echo -e "\r🔍 Executing automated SAST with Nuclei..."

  spinner_run "$NUCLEI_PID"

  if [[ $USE_AI -eq 1 ]]; then
    if [[ -s "$NUCLEI_OUTPUT_TMP" ]]; then
      # Create a temporary file with full-matches added to the Nuclei output
      nuclei_with_full_tmp=$(mktemp)
      add_full_line_match "$NUCLEI_OUTPUT_TMP" >"$nuclei_with_full_tmp"
      # Strip the /tmp/ from matched-at for both the Nuclei output and the AI response later
      nuclei_with_full_stripped_tmp=$(mktemp)
      strip_tmp_from_matched_at "$nuclei_with_full_tmp" >"$nuclei_with_full_stripped_tmp"
      # Use the stripped Nuclei output as input to AI scoring
      AI_RESPONSE_TMPFILE=$(mktemp)
      ai_scoring "$nuclei_with_full_stripped_tmp" "$AI_URL" "$AI_MODEL" "$AI_RESPONSE_TMPFILE"
      # Now, we have:
      #   $nuclei_with_full_stripped_tmp: Nuclei output with full-matches and stripped matched-at
      #   $AI_RESPONSE_TMPFILE: AI results with stripped matched-at (and hopefully full-matches)
      # We will use these two files as input to generateReport.
      NUCLEI_OUTPUT_FOR_REPORT="$nuclei_with_full_stripped_tmp"
      AI_RESPONSE_FOR_REPORT="$AI_RESPONSE_TMPFILE"
    else
      echo "✅ No findings from Nuclei, skipping AI analysis."
      # In this case, we still want to run the non-AI path?
      # We'll set the variables to the original Nuclei output (which is empty) and empty AI response.
      NUCLEI_OUTPUT_FOR_REPORT="$NUCLEI_OUTPUT_TMP"
      AI_RESPONSE_FOR_REPORT="/dev/null"
    fi
  else
    # Non-AI path: create a temporary file with full-matches and stripped matched-at
    if [[ -s "$NUCLEI_OUTPUT_TMP" ]]; then
      nuclei_with_full_tmp=$(mktemp)
      add_full_line_match "$NUCLEI_OUTPUT_TMP" >"$nuclei_with_full_tmp"
      nuclei_with_full_stripped_tmp=$(mktemp)
      strip_tmp_from_matched_at "$nuclei_with_full_tmp" >"$nuclei_with_full_stripped_tmp"
      NUCLEI_OUTPUT_FOR_REPORT="$nuclei_with_full_stripped_tmp"
      AI_RESPONSE_FOR_REPORT="/dev/null"
    else
      NUCLEI_OUTPUT_FOR_REPORT="$NUCLEI_OUTPUT_TMP"
      AI_RESPONSE_FOR_REPORT="/dev/null"
    fi
  fi

  # Run security-scan workflow if enabled
  if [[ "$RUN_SECURITY_SCAN" -eq 1 ]]; then
    echo -e "\r🔒 Executing security-scan workflow..."
    runSecurityScanWorkflow "" "$FILTERED_TARGET_PATH"
    spinner_run "$!" "Running security-scan tools..."
    echo -e "\r📋 Security-scan workflow completed."
    # Set the security scan report path for later use
    security_scan_report="${SECURITY_SCAN_TEMP_DIR}/security-scan-report.md"
  fi

  # Prepare input for report generation
  if [[ "$USE_AI" -eq 1 ]]; then
    if [[ -s "$NUCLEI_OUTPUT_TMP" ]]; then
      # Create a temporary file with full-matches added to the Nuclei output
      nuclei_with_full_tmp=$(mktemp)
      add_full_line_match "$NUCLEI_OUTPUT_TMP" >"$nuclei_with_full_tmp"
      # Strip the /tmp/ from matched-at for both the Nuclei output and the AI response later
      nuclei_with_full_stripped_tmp=$(mktemp)
      strip_tmp_from_matched_at "$nuclei_with_full_tmp" >"$nuclei_with_full_stripped_tmp"

      # Combine Nuclei results with security scan results (if available)
      if [[ "$RUN_SECURITY_SCAN" -eq 1 && -f "$SECURITY_SCAN_COMBINED_JSON" && -s "$SECURITY_SCAN_COMBINED_JSON" ]]; then
        # Combine Nuclei and security scan results
        combined_input_tmp=$(mktemp)
        jq -s '.[0] + .[1]' "$nuclei_with_full_stripped_tmp" "$SECURITY_SCAN_COMBINED_JSON" > "$combined_input_tmp"

        # Use the combined input as input to AI scoring
        AI_RESPONSE_TMPFILE=$(mktemp)
        ai_scoring "$combined_input_tmp" "$AI_URL" "$AI_MODEL" "$AI_RESPONSE_TMPFILE"

        # For the final report generation, we need the AI-enhanced version of the combined input
        NUCLEI_OUTPUT_FOR_REPORT="$combined_input_tmp"
        AI_RESPONSE_FOR_REPORT="$AI_RESPONSE_TMPFILE"
      else
        # No security scan results or security scan not run, use only Nuclei
        # Use the stripped Nuclei output as input to AI scoring
        AI_RESPONSE_TMPFILE=$(mktemp)
        ai_scoring "$nuclei_with_full_stripped_tmp" "$AI_URL" "$AI_MODEL" "$AI_RESPONSE_TMPFILE"

        # For the final report generation, we need the AI-enhanced version
        NUCLEI_OUTPUT_FOR_REPORT="$nuclei_with_full_stripped_tmp"
        AI_RESPONSE_FOR_REPORT="$AI_RESPONSE_TMPFILE"
      fi
    else
      echo "✅ No findings from Nuclei, skipping AI analysis."
      # In this case, we still want to run the non-AI path?
      # We'll set the variables to the original Nuclei output (which is empty) and empty AI response.
      if [[ "$RUN_SECURITY_SCAN" -eq 1 && -f "$SECURITY_SCAN_COMBINED_JSON" && -s "$SECURITY_SCAN_COMBINED_JSON" ]]; then
        # Use only security scan results
        NUCLEI_OUTPUT_FOR_REPORT="$SECURITY_SCAN_COMBINED_JSON"
        AI_RESPONSE_FOR_REPORT="/dev/null"
      else
        # No findings from either source
        NUCLEI_OUTPUT_FOR_REPORT="$NUCLEI_OUTPUT_TMP"
        AI_RESPONSE_FOR_REPORT="/dev/null"
      fi
    fi
  else
    # Non-AI path: create a temporary file with full-matches and stripped matched-at
    if [[ -s "$NUCLEI_OUTPUT_TMP" ]]; then
      nuclei_with_full_tmp=$(mktemp)
      add_full_line_match "$NUCLEI_OUTPUT_TMP" >"$nuclei_with_full_tmp"
      nuclei_with_full_stripped_tmp=$(mktemp)
      strip_tmp_from_matched_at "$nuclei_with_full_tmp" >"$nuclei_with_full_stripped_tmp"

      # Combine Nuclei results with security scan results (if available)
      if [[ "$RUN_SECURITY_SCAN" -eq 1 && -f "$SECURITY_SCAN_COMBINED_JSON" && -s "$SECURITY_SCAN_COMBINED_JSON" ]]; then
        # Combine Nuclei and security scan results
        combined_input_tmp=$(mktemp)
        jq -s '.[0] + .[1]' "$nuclei_with_full_stripped_tmp" "$SECURITY_SCAN_COMBINED_JSON" > "$combined_input_tmp"

        NUCLEI_OUTPUT_FOR_REPORT="$combined_input_tmp"
        AI_RESPONSE_FOR_REPORT="/dev/null"
      else
        # No security scan results or security scan not run, use only Nuclei
        NUCLEI_OUTPUT_FOR_REPORT="$nuclei_with_full_stripped_tmp"
        AI_RESPONSE_FOR_REPORT="/dev/null"
      fi
    else
      # No Nuclei results
      if [[ "$RUN_SECURITY_SCAN" -eq 1 && -f "$SECURITY_SCAN_COMBINED_JSON" && -s "$SECURITY_SCAN_COMBINED_JSON" ]]; then
        # Use only security scan results
        NUCLEI_OUTPUT_FOR_REPORT="$SECURITY_SCAN_COMBINED_JSON"
        AI_RESPONSE_FOR_REPORT="/dev/null"
      else
        # No findings from either source
        NUCLEI_OUTPUT_FOR_REPORT="$NUCLEI_OUTPUT_TMP"
        AI_RESPONSE_FOR_REPORT="/dev/null"
      fi
    fi
  fi

  if [[ "$MODE" == "git" && "$GIT_TARGET_TYPE" -ne 2 ]]; then
    git_exclude_script
  fi

  # Generate the final report using the processed inputs
  generateReport "$NUCLEI_OUTPUT_FOR_REPORT" "$AI_RESPONSE_FOR_REPORT"

  # If High/Critical vulnerabilities found, exit 1, else exit 0
  if [[ "$MAJOR_VULN_FOUND" -eq 1 ]]; then
    exit 1
  else
    exit 0
  fi
}

main "$@"
