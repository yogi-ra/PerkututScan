# shellcheck disable=SC2317
# === Cleanup handler ===
cleanup() {
  [[ -f "$AI_USER_PROMPT" ]] && rm -f "$AI_USER_PROMPT" &>/dev/null
  [[ -f "$AI_RESPONSE_TMPFILE" ]] && rm -f "$AI_RESPONSE_TMPFILE" &>/dev/null
  [[ -f "$NUCLEI_WITH_FULL_TMP" ]] && rm -f "$NUCLEI_WITH_FULL_TMP" &>/dev/null
  [[ -f "$NUCLEI_WITH_FULL_STRIPPED_TMP" ]] && rm -f "$NUCLEI_WITH_FULL_STRIPPED_TMP" &>/dev/null
  [[ -d "$GIT_CLONED_TARGET" ]] && rm -rf "$GIT_CLONED_TARGET" &>/dev/null
  [[ -f "$NUCLEI_OUTPUT_TMP" ]] && rm -f "$NUCLEI_OUTPUT_TMP" &>/dev/null
  [[ -d "/tmp/$(basename "$TARGET")" ]] && rm -rf "/tmp/$(basename "$TARGET")" &>/dev/null
  find /tmp -type d -iname "nuclei*" -exec rm -rf {} \; &>/dev/null
  [[ -d "$SECURITY_SCAN_TEMP_DIR" ]] && rm -rf "$SECURITY_SCAN_TEMP_DIR" &>/dev/null
}
trap cleanup INT TERM

print_help() {
  echo "Usage: $0 [-m MODE] [-t TARGET] [-s] [--ai] [--aih URL] [--aim MODEL] [--aib N] [--aik KEY] [--tools LIST] [-h]"
  echo "  -m      Scan mode (dir, git)"
  echo "  -t      Target directory or repo"
  echo "  -s, --security-scan   Enable security-scan workflow"
  echo "  --tools LIST          Comma-separated list of security tools to run (trivy,bandit,pip-audit,semgrep)"
  echo "  --ai    Enable AI"
  echo "  --aih   AI URL (default: $AI_URL)"
  echo "  --aim   AI Model (default: $AI_MODEL)"
  echo "  --aib   n Findings for AI to score in a batch (default: $AI_BATCH_SIZE)"
  echo "  --aik   AI API Key (default: $AI_API_KEY)"
  echo "  -h      Show help"
}

print_git_help() {
  echo "Git mode help:"
  echo "  -m git -t <repo/git project dir path/current directory(leave blank)>    Scan git project"
  echo "  -s, --security-scan   Enable security-scan workflow"
  echo "  --tools LIST          Comma-separated list of security tools to run (trivy,bandit,pip-audit,semgrep)"
  echo "  --ai    Enable AI"
  echo "  --aih   AI URL (default: $AI_URL)"
  echo "  --aim   AI Model (default: $AI_MODEL)"
  echo "  --aib   n Findings for AI to score in a batch (default: $AI_BATCH_SIZE)"
  echo "  --aik   AI API Key (default: $AI_API_KEY)"
}

print_dir_help() {
  echo "Dir mode help:"
  echo "  -m dir -t <path>    Scan directory"
  echo "  -s, --security-scan   Enable security-scan workflow"
  echo "  --tools LIST          Comma-separated list of security tools to run (trivy,bandit,pip-audit,semgrep)"
  echo "  --ai    Enable AI"
  echo "  --aih   AI URL (default: $AI_URL)"
  echo "  --aim   AI Model (default: $AI_MODEL)"
  echo "  --aib   n Findings for AI to score in a batch (default: $AI_BATCH_SIZE)"
  echo "  --aik   AI API Key (default: $AI_API_KEY)"
}

# === Report generator ===
generateReport() {
  local nuclei_findings_file="$1"
  local ai_analysis_file="$2"
  local final_findings_json=""

  if [[ ! -s "$nuclei_findings_file" ]]; then
    echo -e "\n✅ No vulnerabilities found by Nuclei." | tee "$NUCLEI_REPORT_FILE"
    return
  fi

  # === AI-Enhanced Reporting ===
  if [[ -n "$ai_analysis_file" && -s "$ai_analysis_file" ]]; then
    echo -e "\n🤖 Filtering and enhancing report with AI analysis..."

    final_findings_json=$(jq -s '
      .[0] as $nuclei |
      .[1] as $ai |

      $nuclei | map(
        . as $finding |
        (
          $ai
          | map(select(
              .["template-id"] == $finding["template-id"]
              and ((.["extracted-results"] // []) | map(. as $item | $finding["extracted-results"] | index($item)) | any)
            ))[0] // {}
        ) as $ai_finding |

        $finding + {
          "full-matches": ($ai_finding["full-matches"] // $finding["full-matches"] // []),
          "info": {
            "accuracy": ($ai_finding.accuracy // "N/A"),
            "severity": ($ai_finding.severity // "unknown"),
            "name": $finding.info.name,
            "description": $finding.info.description,
            "ai_reasoning": ($ai_finding.reasoning // "Not provided")
          }
        }
      )
    ' "$nuclei_findings_file" "$ai_analysis_file")
  else
    # === Standard reporting produced by Nuclei ===
    echo -ne "\n📄 Generating standard SAST report..."
    final_findings_json=$(jq -s '.' "$nuclei_findings_file")
  fi

  if [[ "$(echo "$final_findings_json" | jq 'length')" -eq 0 ]]; then
    if [[ -n "$ai_analysis_file" && -s "$ai_analysis_file" ]]; then
      echo -e "\n✅ All findings were classified as false positives by the AI. No vulnerabilities to report." | tee "$NUCLEI_REPORT_FILE"
    else
      echo -e "\n✅ No vulnerabilities found." | tee "$NUCLEI_REPORT_FILE"
    fi
    return
  fi

  echo "====== SAST Report (Generated: $(date)) ======" >"$NUCLEI_REPORT_FILE"
  [[ -n "$ai_analysis_file" && -s "$ai_analysis_file" ]] && echo "====== (AI Analysis Enabled) ======" >>"$NUCLEI_REPORT_FILE"

  total=$(echo "$final_findings_json" | jq '. | length')
  critical=$(echo "$final_findings_json" | jq '[.[] | select(.info.severity == "critical")] | length')
  high=$(echo "$final_findings_json" | jq '[.[] | select(.info.severity == "high")] | length')
  medium=$(echo "$final_findings_json" | jq '[.[] | select(.info.severity == "medium")] | length')
  low=$(echo "$final_findings_json" | jq '[.[] | select(.info.severity == "low")] | length')
  info=$(echo "$final_findings_json" | jq '[.[] | select(.info.severity == "info")] | length')
  unknown=$(echo "$final_findings_json" | jq '[.[] | select(.info.severity == "unknown")] | length')

  {
    echo "Total findings : $total"
    echo "Critical       : $critical"
    echo "High           : $high"
    echo "Medium         : $medium"
    echo "Low            : $low"
    echo "Info           : $info"
    echo "Unknown        : $unknown"
    echo ""
    echo "$final_findings_json" | jq -r '
    .[] |
    ((.info.severity | if type == "string" then . else "UNKNOWN" end) | ascii_upcase) as $severity_text |
    "\( $severity_text ): " +
    "\(.info.name // "N/A")\n" +
    "     DESCRIPTION        -> \(.info.description // "N/A")\n" +
    "     MATCHED-AT         -> \(.["matched-at"] // "N/A")\n" +
    "     MATCH-STRING       -> \((.["extracted-results"] // []) | join(", "))\n" +
    "     FULL-MATCH-STRING  -> \((.["full-matches"] // []) | join(", "))\n" +
    (if .info.ai_reasoning then
    "     ACCURACY           -> \(.info.accuracy // "N/A")\n" else "" end) +
    (if .info.ai_reasoning then
    "     AI REASONING       -> \(.info.ai_reasoning // "N/A")" else "" end) +
    "\n"
  '
  } >>"$NUCLEI_REPORT_FILE"

  echo -e "\r📦 SAST Report saved to: $(realpath "$NUCLEI_REPORT_FILE")"

  if [[ "$critical" -gt 0 || "$high" -gt 0 ]]; then
    MAJOR_VULN_FOUND=1
  fi
}

# === Dependency check ===
checkDependencies() {
  # These are dependencies that are possibly not available on minimal systems.
  local dependencies=(file nuclei rsync jq curl)

  for dep in "${dependencies[@]}"; do
    if ! command -v "$dep" &>/dev/null; then
      echo "❌ Missing dependency: $dep"
      exit 1
    fi
  done
}

checkSecurityScanDependencies() {
  # Check for dependencies needed for security-scan workflow
  local trivy_available=false
  local semgrep_available=false
  local bandit_available=false
  local pip_audit_available=false
  local missing_tools=()

  if command -v semgrep >/dev/null 2>&1; then
    semgrep_available=true
  else
    missing_tools+=("semgrep")
  fi

  if command -v trivy >/dev/null 2>&1; then
    trivy_available=true
  else
    missing_tools+=("trivy")
  fi

  # Check Bandit (for Python security issues)
  if command -v bandit >/dev/null 2>&1; then
    bandit_available=true
  else
    missing_tools+=("bandit")
  fi

  # Check Pip-Audit (for dependency vulnerability checking)
  if command -v pip-audit >/dev/null 2>&1; then
    pip_audit_available=true
  else
    missing_tools+=("pip-audit")
  fi

  # Store availability in global variables for use in tool functions
  SECURITY_SCAN_TRIVY_AVAILABLE=$trivy_available
  SECURITY_SCAN_SEMGREP_AVAILABLE=$semgrep_available
  SECURITY_SCAN_BANDIT_AVAILABLE=$bandit_available
  SECURITY_SCAN_PIP_AUDIT_AVAILABLE=$pip_audit_available

  # Warn about missing tools but don't exit - we'll handle gracefully in each tool function
  if [[ ${#missing_tools[@]} -gt 0 ]]; then
    echo "⚠️  Warning: Missing security-scan dependencies: ${missing_tools[*]}"
    echo "   Some security-scan tools may be skipped."
  fi
}

git_exclude_script() {
  local project_path
  project_path="$(git rev-parse --show-toplevel)/.git/info"
  if test -f "$project_path/exclude.bak"; then
    mv "$project_path/exclude.bak" "$project_path/exclude"
  elif test -f "$project_path/exclude"; then
    cp "$project_path/exclude" "$project_path/exclude.bak"
  fi
}

ignoreSASTFile() {
  local the_file="$1"
  local exclude_file
  exclude_file="$(git rev-parse --show-toplevel)/.git/info/exclude"
  if ! grep -q "$the_file" "$exclude_file" 2>/dev/null; then
    echo "$the_file" >>"$exclude_file"
    echo "📁 Added $the_file to $exclude_file"
  fi
}

naive_ai_text_response_to_json() {
  local ai_response="$1"
  # Find the first '[' and the last ']' to extract the JSON array
  if [[ "$ai_response" =~ (\[.*\]) ]]; then
    echo "${BASH_REMATCH[1]}"
  else
    echo "❌ No valid JSON array found in AI response" >&2
    echo "--- AI Response Content ---" >&2
    echo "$ai_response" >&2
    echo "---------------------------" >&2
    echo "[]"
  fi
}

filter_useful_nuclei_data() {
  local input_file="$1"

  jq -s '
    (if type == "array" and (.[0]|type) == "array" then .[0] else . end) |
    map({
      "template-id": ."template-id",
      "matched-at": ."matched-at",
      "extracted-results": ."extracted-results",
      "severity": .info.severity
    })
  ' "$input_file"
}

add_full_line_match() {
  local nuclei_json_file="$1"
  mapfile -t entries < <(jq -c '.[]' "$nuclei_json_file")
  updated_entries=()

  for entry in "${entries[@]}"; do
    local file_path
    local keyword_found
    file_path=$(jq -r '."matched-at"' <<<"$entry")
    [[ -f "$file_path" ]] || continue
    mapfile -t keywords < <(jq -r '."extracted-results"[]' <<<"$entry")
    matched_lines=()

    for keyword_found in "${keywords[@]}"; do
      while IFS= read -r line; do
        matched_lines+=("$(cut -c1-300 <<<"$line")")
      done < <(grep -I -F "$keyword_found" "$file_path")
    done

    mapfile -t full_lines < <(printf '%s\n' "${matched_lines[@]}" | sort -u)

    local matches_json
    matches_json=$(printf '%s\n' "${full_lines[@]}" | jq -R . | jq -s .)
    updated_entries+=("$(jq --argjson matches "$matches_json" '.["full-matches"] = $matches' <<<"$entry")")
  done
  printf '[%s]\n' "$(
    IFS=,
    echo "${updated_entries[*]}"
  )"
}

ai_scoring() {
  local nuclei_output_file="$1"
  local ai_url="$2"
  local ai_model="$3"
  local output_file="$4" # File to save final JSON to
  local url
  local curl_pid
  local batch_ai_response

  AI_USER_PROMPT="$(mktemp)"
  SYSTEM_PROMPT=$(
    cat <<EOF
You are a specialized SAST analysis bot. Your ONLY function is to analyze JSON data of security findings and return a JSON array as a response.
You will receive a JSON array of findings. For each finding, evaluate its accuracy based on the provided code context in \$(full-matches).
Your response MUST be a valid JSON array. Do not output ANY text, markdown, or explanations before or after the JSON array.

For each object in the input array, create a corresponding object in your output array with these fields:
- "template-id": (string) The original \$(template-id).
- "matched-at": (string) The original \$(matched-at).
- "extracted-results": (array) The original \$(extracted-results).
- "accuracy": (integer) 1 for a true positive, 0 for a false positive. Base this on code context. A hardcoded secret is accuracy 1. A match in a comment is accuracy 0.
- "severity": (string) Re-evaluate the severity to one of ["critical", "high", "medium", "low", "info"] based on real-world impact shown in the code.
- "reasoning": (string) A very brief, one-sentence justification.
EOF
  )

  {
    nuclei_useful_filter_tmp=$(mktemp)
    filter_useful_nuclei_data "$nuclei_output_file" >"$nuclei_useful_filter_tmp"
    mv "$nuclei_useful_filter_tmp" "$AI_USER_PROMPT"

    added_full_line_tmp=$(mktemp)
    add_full_line_match "$AI_USER_PROMPT" >"$added_full_line_tmp"
    if [[ -s "$added_full_line_tmp" ]]; then
      mv "$added_full_line_tmp" "$AI_USER_PROMPT"
    else
      rm -f "$added_full_line_tmp"
    fi
  } &
  spinner_run "$!" "Preparing user prompt..."

  if [[ ! -s "$AI_USER_PROMPT" || "$(jq 'length' "$AI_USER_PROMPT")" -eq 0 ]]; then
    echo "[]" >"$output_file"
    echo -e "\nNo findings to send to AI. Skipping."
    return
  fi

  # === Batch processing starts here ===
  local total_findings=""
  total_findings=$(jq 'length' "$AI_USER_PROMPT")
  local num_batches=""
  num_batches=$(((total_findings + AI_BATCH_SIZE - 1) / AI_BATCH_SIZE))

  echo -e "\rTotal findings to analyze: $total_findings. Splitting into $num_batches batches of size $AI_BATCH_SIZE."

  local all_ai_results_tmp
  all_ai_results_tmp=$(mktemp)
  echo "[]" >"$all_ai_results_tmp"

  url="${ai_url}/chat/completions"

  for ((i = 0; i < num_batches; i++)); do
    local batch_num=$((i + 1))
    local batch_prompt_file

    batch_prompt_file=$(mktemp)

    jq --argjson i "$i" --argjson size "$AI_BATCH_SIZE" '.[($i * $size):($i * $size + $size)]' "$AI_USER_PROMPT" >"$batch_prompt_file"

    if [[ ! -s "$batch_prompt_file" ]]; then
      rm -f "$batch_prompt_file"
      continue
    fi

    batch_ai_response="$(mktemp)"
    {
      temp_json_file=$(mktemp)

      jq -n --arg model "$ai_model" \
        --arg system "$SYSTEM_PROMPT" \
        --rawfile prompt "$batch_prompt_file" \
        '{
          model: $model,
          messages: [
            {"role": "system", "content": $system},
            {"role": "user", "content": $prompt}
          ], stream: false
        }' >"$temp_json_file"

      curl -s -X POST "$url" -H "Authorization: Bearer $AI_API_KEY" -H "Content-Type: application/json" -d @"$temp_json_file" >"$batch_ai_response"
      rm -f "$temp_json_file" "$batch_prompt_file"
    } &

    curl_pid=$!
    spinner_run "$curl_pid" "🤖 Running AI Scoring (Batch $batch_num of $num_batches)..."
    echo -ne "\r\033[K"

    # Process the AI response for current batch
    if [[ ! -s "$batch_ai_response" ]]; then
      echo "❌ AI did not return a response for batch $batch_num." >&2
      continue
    fi

    local ai_raw_text_response=""
    ai_raw_text_response=$(jq -r '.choices[0].message.content' "$batch_ai_response")
    if [[ -z "$ai_raw_text_response" || "$ai_raw_text_response" == "null" ]]; then
      echo "❌ AI response content is empty for batch $batch_num." >&2
      if jq -e '.error' "$batch_ai_response" >/dev/null; then
        echo "AI returned an error: $(jq -r '.error' "$batch_ai_response")" >&2
      fi
      continue
    fi

    local cleaned_response=""
    cleaned_response=$(echo "$ai_raw_text_response" | sed -e 's/^```json//' -e 's/^```//' -e 's/```$//')

    local batch_json_result=""
    batch_json_result=$(naive_ai_text_response_to_json "$cleaned_response")

    if echo "$batch_json_result" | jq -e . >/dev/null 2>&1; then
      if [[ $(echo "$batch_json_result" | jq 'length') -gt 0 ]]; then
        local combined_results=""
        combined_results=$(jq -s '.[0] + .[1]' "$all_ai_results_tmp" <(echo "$batch_json_result"))
        echo "$combined_results" >"$all_ai_results_tmp"
      fi
    fi
    # Skipping if invalid.
  done

  rm -f "$batch_ai_response"
  mv "$all_ai_results_tmp" "$output_file"
  echo -e "\n✅ AI analysis complete. All batches processed."
}

strip_tmp_from_matched_at() {
  local input_file="$1"
  if [[ "$GIT_TARGET_TYPE" -ne 2 ]]; then
    jq --arg target "$(realpath "$TARGET")" \
      '
      map(
        .["matched-at"] |= (
          match("^/tmp/[^/]+(/.*)?")
          | $target + (.captures[0].string // "")
        )
      )
    ' "$input_file"
  else
    jq \
      '
      map(
        .["matched-at"] |= (
          match("^/tmp/[^/]+/[^/]+(/.*)?")
          | (.captures[0].string // "")
        )
      )
    ' "$input_file"
  fi
}

run_prepare() {
  local source="$1"
  local clean_target

  clean_target="/tmp/$(basename "$TARGET")"

  rsync -a "$source/" "$clean_target" \
    --exclude=".git*" \
    --exclude=".github*" \
    --exclude=".svn" \
    --exclude=".hg" \
    --exclude=".bzr" \
    --exclude=".vscode" \
    --exclude=".idea" \
    --exclude="Dockerfile*" \
    --exclude="Jenkinsfile*" \
    --exclude="node_modules" \
    --exclude="dist" \
    --exclude="build" \
    --exclude="venv" \
    --exclude="__pycache__" \
    --exclude="*.swp" \
    --exclude="*.bak" \
    --exclude="*~" \
    --exclude=".DS_Store" \
    --exclude="Thumbs.db" \
    --exclude="*README*" \
    --exclude="*LICENSE*" \
    --exclude="*CHANGELOG*" \
    --exclude="*CONTRIBUTING*" \
    --exclude="*docs*" \
    --exclude="*.md" \
    --exclude="*.rst" \
    --exclude="*.jpg" \
    --exclude="*.jpeg" \
    --exclude="*.png" \
    --exclude="*.gif" \
    --exclude="*.svg" \
    --exclude="*.pdf" \
    --exclude="*.mp4" \
    --exclude="*.zip" \
    --exclude="*.tar.gz" \
    --exclude="*.exe" \
    --exclude="*.dll" \
    --exclude="*.so" \
    --exclude="test" \
    --exclude="tests" \
    --exclude="*.test.*" \
    --exclude="*.spec.*" \
    --exclude="*.mock.*" \
    --exclude="sast-report.txt" \
    &>/dev/null

  echo "$clean_target"
}

print_full_width_spaces() {
  local cols
  cols=$(stty size 2>/dev/null | awk '{print $2}')
  printf '\r%*s' "${cols:-80}" ""
}

spinner_run() {
  local custom_text="${2:-Scanning file(s)...}"
  local spinner=""
  local current_spinner_index=0
  local spinner_ascii=("⠋" "⠙" "⠸" "⠴" "⠦" "⠇")

  print_full_width_spaces
  while ps -p "$1" &>/dev/null; do # PID goes here
    spinner="${spinner_ascii[$current_spinner_index]}"
    if [[ $((current_spinner_index + 1)) -eq ${#spinner_ascii[@]} ]]; then
      current_spinner_index=0
    else
      current_spinner_index=$((current_spinner_index + 1))
    fi
    echo -ne "\r$spinner $custom_text"
    sleep 0.1
  done
}

parse_args() {
  while (($#)); do
    case "$1" in
    -m)
      MODE=$2
      shift 2
      ;;
    -t)
      TARGET=$2
      shift 2
      ;;
    -s)
      RUN_SECURITY_SCAN=1
      shift
      ;;
    -h)
      SHOW_HELP=1
      shift
      ;;
    --ai)
      USE_AI=1
      shift
      ;;
    --aih)
      AI_URL=$2
      shift 2
      ;;
    --aim)
      AI_MODEL=$2
      shift 2
      ;;
    --aib)
      AI_BATCH_SIZE=$2
      shift 2
      ;;
    --aik)
      AI_API_KEY=$2
      shift 2
      ;;
    --security-scan)
      RUN_SECURITY_SCAN=1
      shift
      ;;
    --tools)
      SECURITY_SCAN_TOOLS=$2
      shift 2
      ;;
    --)
      shift
      break
      ;; # stop parsing
    *)
      echo "❌ Unexpected option: $1"
      exit 1
      ;;
    esac
  done

  # Positional target (if -t was omitted)
  if [[ -z "$TARGET" && $# -gt 0 ]]; then
    TARGET=$1
    shift
  fi

  if (($#)); then
    echo "❌ Unexpected positional argument(s): $*"
    exit 1
  fi
}

runSemgrepScan() {
  local source="$1"
  local real_target="$2"
  local temp_dir="$3"

  if [[ "$SECURITY_SCAN_SEMGREP_AVAILABLE" ]]; then
    echo "⚠️  Skipping Semgrep scan (Semgrep not available)"
    return
  fi

  echo "🔍 Running Semgrep Security Audit..."
  {
    echo "## Semgrep Security Audit (OWASP Top Ten & General Security)"
    echo ""
    echo "Command: semgrep --config p/security-audit --config p/owasp-top-ten /src --json"
    echo ""
    echo "Output:"
    echo "$()$("semgrep --config p/security-audit --config p/owasp-top-ten /src --json")$()"
    echo ""
  } >>"${temp_dir}/security-scan-report.md"
}

runTrivyScan() {
  local source="$1"
  local real_target="$2"
  local temp_dir="$3"

  if [[ "$SECURITY_SCAN_TRIVY_AVAILABLE" ]]; then
    echo "⚠️  Skipping Trivy scan (Trivy not available)"
    return
  fi

  if trivy fs /src \
    --scanners vuln,secret \
    --vuln-type os,library \
    --format json >"${temp_dir}/security_scan_report.md" 2>/dev/null; then
    :
  else
    echo "[]" >"${temp_dir}/security_scan_report.md"
  fi

  local trivy_rootfs_output="${temp_dir}/trivy_rootfs.txt"
  echo "🔍 Running Trivy RootFS Scan..."
  {
    echo "## Trivy RootFS Scan"
    echo ""
    echo "Command: trivy rootfs /src"
    echo ""
    echo "Output:"
    echo "
    $()$("trivy rootfs /src 2>/dev/null || echo 'RootFS scan skipped (not applicable or requires root)' | tee "${trivy_rootfs_output}" echo ")$()"
    echo ""
  } >>"${temp_dir}/security-scan-report.md"
}

runBanditScan() {
  local source="$1"
  local real_target="$2"
  local temp_dir="$3"

  if [[ "$SECURITY_SCAN_BANDIT_AVAILABLE" != "true" ]]; then
    echo "⚠️  Skipping Bandit scan (bandit not available)"
    return
  fi

  echo "🔍 Running Bandit Security Scan..."
  {
    echo "## Bandit Security Scan (Python-specific issues)"
    echo ""
    echo "Command: bandit -r \"${real_target}\" -lll --format txt"
    echo ""
    echo "Output:"
    echo ""
    echo ""
  } >>"${temp_dir}/security-scan-report.md"
}

runPipAuditScan() {
  local source="$1"
  local real_target="$2"
  local temp_dir="$3"

  if [[ "$SECURITY_SCAN_PIP_AUDIT_AVAILABLE" != "true" ]] || [[ ! -f "${real_target}/requirements.txt" ]]; then
    if [[ ! -f "${real_target}/requirements.txt" ]]; then
      echo "⚠️  Skipping Pip-Audit scan (requirements.txt not found)"
    else
      echo "⚠️  Skipping Pip-Audit scan (pip-audit not available)"
    fi
    return
  fi

  echo "🔍 Running Pip-Audit Dependency Vulnerability Check..."
  {
    echo "## Pip-Audit Dependency Vulnerability Check"
    echo ""
    echo "Command: pip-audit -r \"${real_target}/requirements.txt\" --format txt"
    echo ""
    echo "Output:"
    echo "$()$("pip-audit -r "${real_target}/requirements.txt" --format txt | tee \"${temp_dir}/pip-audit.txt\"")$()"
    echo ""
  } >>"${temp_dir}/security-scan-report.md"

  # Also generate JSON output for integration with main report
  if command -v pip-audit >/dev/null 2>&1 && [[ -f "${real_target}/requirements.txt" ]]; then
    # Create temporary file for pip-audit JSON output
    local pip_audit_json_output="${temp_dir}/pip-audit.json"
    echo "[]" >"$pip_audit_json_output" # Start with empty array

    # Process pip-audit output line by line (txt format)
    # Format: package: version: vulnerability ID [more info]
    while IFS= read -r line; do
      if [[ -n "$line" && ! "$line" =~ ^[[:space:]]*$ && ! "$line" =~ ^Scanning && ! "$line" =~ ^Collecting ]]; then
        # Parse pip-audit output: package: version: vulnerability ID
        # Example: "django: 2.0.0: CVE-2019-14234"
        if [[ "$line" =~ : ]]; then
          IFS=':' read -r pkg_ver vuln <<<"$line"
          # Further split package and version
          IFS=' ' read -r package version <<<"$pkg_ver"
          # Remove leading/trailing whitespace
          package=$(echo "$package" | xargs)
          version=$(echo "$version" | xargs)
          vuln=$(echo "$vuln" | xargs)

          if [[ -n "$package" && -n "$version" && -n "$vuln" ]]; then
            # Create JSON object for this finding
            local json_obj=$(jq -n \
              --arg pkg "$package" \
              --arg ver "$version" \
              --arg vuln "$vuln" \
              '{template-id: "pip-audit-" + $vuln, matched-at: "requirements.txt", extracted-results: [$pkg, $ver], severity: "high"}')

            # Append to array
            if [[ -f "$pip_audit_json_output" ]]; then
              jq --argjson new "$json_obj" '. + [$new]' "$pip_audit_json_output" >"${pip_audit_json_output}.tmp" && mv "${pip_audit_json_output}.tmp" "$pip_audit_json_output"
            fi
          fi
        fi
      fi
    done < <(pip-audit -r "${real_target}/requirements.txt" --format txt 2>/dev/null || true)
  fi
}

runSecurityScanWorkflow() {
  local source="$1"
  local real_target="$2"

  SECURITY_SCAN_TEMP_DIR=$(mktemp -d)
  SECURITY_SCAN_COMBINED_JSON="${SECURITY_SCAN_TEMP_DIR}/combined-security-results.json"
  echo "[]" >"$SECURITY_SCAN_COMBINED_JSON"

  {
    echo "# Security Scan Report"
    echo "**Date:** $(date)"
    echo "**Project:** $(basename "$real_target")"
    echo ""
  } >"${SECURITY_SCAN_TEMP_DIR}/security-scan-report.md"

  IFS=',' read -ra TOOLS_ARRAY <<<"$SECURITY_SCAN_TOOLS"

  for tool in "${TOOLS_ARRAY[@]}"; do
    case "$tool" in
    trivy)
      echo "🚀 Running Trivy scans…"
      runTrivyScan "$source" "$real_target" "$SECURITY_SCAN_TEMP_DIR"
      # Merge JSON results (ignore missing files – jq will treat them as null)
      if [[ -s "${SECURITY_SCAN_TEMP_DIR}/trivy_filesystem.json" ]]; then
        jq -s '.[0] + .[1]' "$SECURITY_SCAN_COMBINED_JSON" "${SECURITY_SCAN_TEMP_DIR}/trivy_filesystem.json" >"${SECURITY_SCAN_COMBINED_JSON}.tmp" && mv "${SECURITY_SCAN_COMBINED_JSON}.tmp" "$SECURITY_SCAN_COMBINED_JSON"
      fi
      if [[ -s "${SECURITY_SCAN_TEMP_DIR}/trivy_rootfs.json" ]]; then
        jq -s '.[0] + .[1]' "$SECURITY_SCAN_COMBINED_JSON" "${SECURITY_SCAN_TEMP_DIR}/trivy_rootfs.json" >"${SECURITY_SCAN_COMBINED_JSON}.tmp" && mv "${SECURITY_SCAN_COMBINED_JSON}.tmp" "$SECURITY_SCAN_COMBINED_JSON"
      fi
      ;;
    bandit)
      echo "🚀 Running Bandit scan…"
      runBanditScan "$source" "$real_target" "$SECURITY_SCAN_TEMP_DIR"
      if [[ -s "${SECURITY_SCAN_TEMP_DIR}/bandit.json" ]]; then
        jq -s '.[0] + .[1]' "$SECURITY_SCAN_COMBINED_JSON" "${SECURITY_SCAN_TEMP_DIR}/bandit.json" >"${SECURITY_SCAN_COMBINED_JSON}.tmp" && mv "${SECURITY_SCAN_COMBINED_JSON}.tmp" "$SECURITY_SCAN_COMBINED_JSON"
      fi
      ;;
    pip-audit)
      echo "🚀 Running pip‑audit scan…"
      runPipAuditScan "$source" "$real_target" "$SECURITY_SCAN_TEMP_DIR"
      if [[ -s "${SECURITY_SCAN_TEMP_DIR}/pip-audit.json" ]]; then
        jq -s '.[0] + .[1]' "$SECURITY_SCAN_COMBINED_JSON" "${SECURITY_SCAN_TEMP_DIR}/pip-audit.json" >"${SECURITY_SCAN_COMBINED_JSON}.tmp" && mv "${SECURITY_SCAN_COMBINED_JSON}.tmp" "$SECURITY_SCAN_COMBINED_JSON"
      fi
      ;;
    semgrep)
      echo "🚀 Running Semgrep scan…"
      runSemgrepScan "$source" "$real_target" "$SECURITY_SCAN_TEMP_DIR"
      if [[ -s "${SECURITY_SCAN_TEMP_DIR}/semgrep.json" ]]; then
        jq -s '.[0] + .[1]' "$SECURITY_SCAN_COMBINED_JSON" "${SECURITY_SCAN_TEMP_DIR}/semgrep.json" >"${SECURITY_SCAN_COMBINED_JSON}.tmp" && mv "${SECURITY_SCAN_COMBINED_JSON}.tmp" "$SECURITY_SCAN_COMBINED_JSON"
      fi
      ;;
    *)
      echo "⚠️  Unknown security‑scan tool: $tool"
      ;;
    esac
  done

  export SECURITY_SCAN_COMBINED_JSON
  echo "🗂️  Combined security JSON at: $SECURITY_SCAN_COMBINED_JSON"
}

generateSecurityScanReportSection() {
  local security_scan_report_file="$1"
  local main_report_file="$2"

  if [[ ! -f "$security_scan_report_file" ]] || [[ ! -s "$security_scan_report_file" ]]; then
    echo -e "\n⚠️  No security-scan results to include in report." >>"$main_report_file"
    return
  fi

  echo -e "\n\n====== Security-scan Results (Generated: $(date)) =======" >>"$main_report_file"
  cat "$security_scan_report_file" >>"$main_report_file"
}

git_mode_run() {
  if [[ "$GIT_TARGET_TYPE" -eq 0 ]]; then
    local original_target="$(git rev-parse --show-toplevel)"
    FILTERED_TARGET_PATH=$(run_prepare "$original_target")
  elif [[ "$GIT_TARGET_TYPE" -eq 1 ]]; then
    local original_target="$(cd "$TARGET" && git rev-parse --show-toplevel)"
    FILTERED_TARGET_PATH=$(run_prepare "$original_target")
  elif [[ "$GIT_TARGET_TYPE" -eq 2 ]]; then
    GIT_CLONED_TARGET="$(mktemp -d "/tmp/$(basename "$TARGET").XXXXXX")"

    git clone --depth 1 "$TARGET" "$GIT_CLONED_TARGET" &>/dev/null &
    spinner_run "$!" "Cloning git repository..."

    TARGET=$(cut -d. -f1 < <(echo "$GIT_CLONED_TARGET"))
    FILTERED_TARGET_PATH=$(run_prepare "$GIT_CLONED_TARGET")
  else
    exit 1
  fi

  if [[ "$GIT_TARGET_TYPE" -ne 2 ]]; then
    git_exclude_script
    ignoreSASTFile "$NUCLEI_SAST_REPORT_FILE"
  fi

  NUCLEI_OUTPUT_TMP=$(mktemp)
  NUCLEI_REPORT_FILE="$original_target/$NUCLEI_SAST_REPORT_FILE"

  {
    nuclei -file -u "$FILTERED_TARGET_PATH" \
      -s "info,low,medium,high,critical,unknown" \
      -ud "$NUCLEI_TEMPLATE_DIR" \
      -je "$NUCLEI_OUTPUT_TMP" &>/dev/null
  } &
  NUCLEI_PID=$!
}

dir_mode_run() {
  FILTERED_TARGET_PATH=$(run_prepare "$TARGET")

  NUCLEI_OUTPUT_TMP=$(mktemp)
  NUCLEI_REPORT_FILE="$TARGET/$NUCLEI_SAST_REPORT_FILE"
  {
    nuclei -file -u "$FILTERED_TARGET_PATH" \
      -s "info,low,medium,high,critical,unknown" \
      -ud "$NUCLEI_TEMPLATE_DIR" \
      -je "$NUCLEI_OUTPUT_TMP" &>/dev/null
  } &

  NUCLEI_PID=$!

}

main() {
  # Default configurable variables
  AI_URL="http://localhost:11434/v1"
  AI_MODEL="gemma3:latest"
  AI_API_KEY="ollama"
  AI_BATCH_SIZE=5

  # Security-scan variables
  RUN_SECURITY_SCAN=0
  SECURITY_SCAN_TOOLS="trivy,bandit,pip-audit,semgrep" # Default to all tools
  FILTERED_TARGET_PATH=""                              # Path to filtered target directory for scanning

  AI_USER_PROMPT=""
  AI_RESPONSE_TMPFILE=""
  GIT_TARGET_TYPE=-1   # Type 0: Current Directory, 1: Specified Directory, 2: Git Repo URL
  GIT_CLONED_TARGET="" # For git Type 2
  MODE=""
  MAJOR_VULN_FOUND=0
  NUCLEI_PID=""
  NUCLEI_REPORT_FILE=""
  NUCLEI_OUTPUT_TMP=""
  NUCLEI_SAST_REPORT_FILE="sast-report.txt"
  SHOW_HELP=0
  TARGET=""
  USE_AI=0
  NUCLEI_WITH_FULL_TMP=""
  NUCLEI_WITH_FULL_STRIPPED_TMP=""

  parse_args "$@"

  if [[ $SHOW_HELP -eq 1 ]]; then
    case "$MODE" in
    git)
      print_git_help
      ;;
    dir)
      print_dir_help
      ;;
    *)
      echo -e "The mode option should be (git, or dir)\n"
      print_help
      ;;
    esac
    exit 0
  fi

  # GIT_TARGET_TYPE
  # 0: Current Directory
  # 1: Specified Directory
  # 2: Git Repo URL
  if [[ "$MODE" == "git" ]]; then
    if [[ -z "$TARGET" ]] && git status &>/dev/null; then
      GIT_TARGET_TYPE=0
      TARGET=$(git rev-parse --show-toplevel)
    elif [[ -d "$TARGET" ]] && git -C "$TARGET" status &>/dev/null; then
      GIT_TARGET_TYPE=1
      TARGET=$(realpath "$TARGET")
    elif curl -s --head --fail "$TARGET" &>/dev/null; then
      GIT_TARGET_TYPE=2
    else
      print_git_help
      exit 1
    fi
  elif [[ "$MODE" == "dir" ]]; then
    if [[ -z "$TARGET" || ! -d "$(realpath "$TARGET")" ]]; then
      print_dir_help
      exit 1
    fi
  else
    echo -e "❌ No valid mode (-m) provided.\n"
    print_help
    exit 1
  fi

  checkDependencies

  # Check security-scan dependencies if security-scan is enabled
  if [[ "$RUN_SECURITY_SCAN" -eq 1 ]]; then
    checkSecurityScanDependencies
  fi

  # Check if Nuclei is already running
  if ps -p $(pgrep nuclei) >/dev/null 2>&1; then
    echo "❌ Nuclei is already running in another process. Please wait for it to finish."
    exit 1
  fi

  NUCLEI_TEMPLATE_DIR="${HOME}/nuclei-templates"
  if [ "$MODE" == "dir" ]; then
    dir_mode_run
  elif [ "$MODE" == "git" ]; then
    git_mode_run
  else
    print_help
    exit 1
  fi

  echo -e "\r🔍 Executing automated SAST with Nuclei..."

  spinner_run "$NUCLEI_PID"

  if [[ $USE_AI -eq 1 ]]; then
    if [[ -s "$NUCLEI_OUTPUT_TMP" ]]; then
      NUCLEI_WITH_FULL_TMP=$(mktemp)
      add_full_line_match "$NUCLEI_OUTPUT_TMP" >"$NUCLEI_WITH_FULL_TMP"

      NUCLEI_WITH_FULL_STRIPPED_TMP=$(mktemp)
      strip_tmp_from_matched_at "$NUCLEI_WITH_FULL_TMP" >"$NUCLEI_WITH_FULL_STRIPPED_TMP"

      AI_RESPONSE_TMPFILE=$(mktemp)
      ai_scoring "$NUCLEI_WITH_FULL_STRIPPED_TMP" "$AI_URL" "$AI_MODEL" "$AI_RESPONSE_TMPFILE"

      NUCLEI_OUTPUT_FOR_REPORT="$NUCLEI_WITH_FULL_STRIPPED_TMP"
      AI_RESPONSE_FOR_REPORT="$AI_RESPONSE_TMPFILE"
    else
      echo "✅ No findings from Nuclei, skipping AI analysis."
      NUCLEI_OUTPUT_FOR_REPORT="$NUCLEI_OUTPUT_TMP"
      AI_RESPONSE_FOR_REPORT="/dev/null"
    fi
  else
    # Non-AI path: create a temporary file with full-matches and stripped matched-at
    if [[ -s "$NUCLEI_OUTPUT_TMP" ]]; then
      NUCLEI_WITH_FULL_TMP=$(mktemp)
      add_full_line_match "$NUCLEI_OUTPUT_TMP" >"$NUCLEI_WITH_FULL_TMP"
      NUCLEI_WITH_FULL_STRIPPED_TMP=$(mktemp)
      strip_tmp_from_matched_at "$NUCLEI_WITH_FULL_TMP" >"$NUCLEI_WITH_FULL_STRIPPED_TMP"
      NUCLEI_OUTPUT_FOR_REPORT="$NUCLEI_WITH_FULL_STRIPPED_TMP"
      AI_RESPONSE_FOR_REPORT="/dev/null"
    else
      NUCLEI_OUTPUT_FOR_REPORT="$NUCLEI_OUTPUT_TMP"
      AI_RESPONSE_FOR_REPORT="/dev/null"
    fi
  fi

  # Run security-scan workflow if enabled
  if [[ "$RUN_SECURITY_SCAN" -eq 1 ]]; then
    echo -e "\r🔒 Executing security-scan workflow..."
    runSecurityScanWorkflow "" "$FILTERED_TARGET_PATH"
    spinner_run "$!" "Running security-scan tools..."
    echo -e "\r📋 Security-scan workflow completed."
  fi

  if [[ "$MODE" == "git" && "$GIT_TARGET_TYPE" -ne 2 ]]; then
    git_exclude_script
  fi

  # Generate the final report using the processed inputs
  generateReport "$NUCLEI_OUTPUT_FOR_REPORT" "$AI_RESPONSE_FOR_REPORT"
  generateSecurityScanReportSection "$SECURITY_SCAN_COMBINED_JSON" "$NUCLEI_REPORT_FILE"

  cleanup

  # If High/Critical vulnerabilities found, exit 1, else exit 0
  if [[ "$MAJOR_VULN_FOUND" -eq 1 ]]; then
    exit 1
  else
    exit 0
  fi
}

main "$@"
